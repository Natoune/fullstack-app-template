{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["out-tsc", "dist", "**/*.spec.ts", "**/*_spec.ts"],
  "references": [
    {
      "path": "../../packages/shared/tsconfig.app.json"
    }
  ]
}
