{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "esnext",
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": [
    "**/*.spec.ts",
    "**/*.spec.js",
    "**/*.d.ts",
    "src/lib/types/index.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
