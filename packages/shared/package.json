{
  "name": "@fullstack-app-template/shared",
  "version": "0.0.1",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "svelte": "./dist/components/index.js",
      "import": "./dist/components/index.js"
    },
    "./components/*.svelte": {
      "types": "./dist/components/*.d.ts",
      "svelte": "./dist/components/*.svelte",
      "import": "./dist/components/*.svelte"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    }
  },
  "nx": {
    "name": "shared",
    "tags": [
      "shared",
      "ui",
      "utils",
      "app"
    ],
    "targets": {
      "check": {
        "executor": "nx:run-commands",
        "options": {
          "command": "svelte-check",
          "cwd": "packages/shared"
        }
      },
      "add": {
        "executor": "@nxext/sveltekit:add"
      },
      "lint": {
        "command": "eslint packages/shared/**/*.{ts,svelte,spec.ts}"
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "svelte-package",
            "tsc --project tsconfig.app.json"
          ],
          "parallel": false,
          "cwd": "packages/shared"
        }
      },
      "serve": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build"
        ],
        "options": {
          "commands": [
            "svelte-package --watch --preserve-output",
            "tsc-watch --project tsconfig.app.json --noClear"
          ],
          "parallel": true,
          "cwd": "packages/shared"
        }
      }
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^24.13.3",
    "svelte-preprocess": "^6.0.5",
    "tsc-watch": "^7.2.1",
    "typescript": "~6.0.3",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "type": "module"
}
