{
  "name": "@fullstack-app-template/shared",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "shared",
    "tags": [
      "shared",
      "ui",
      "utils"
    ],
    "sourceRoot": "packages/shared/src",
    "targets": {
      "build": {
        "executor": "@nx/vite:rollup",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/shared/dist",
          "project": "packages/shared/vite.config.ts",
          "configFile": "packages/shared/vite.config.ts"
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0"
  }
}
